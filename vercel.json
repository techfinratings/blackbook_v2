{
  "version": 2,
  "functions": {
    "api/calendar.js": { "regions": ["icn1"] },
    "api/post.js": { "regions": ["icn1"] },
    "api/guide.js": { "regions": ["icn1"] },
    "api/sitemap.js": { "regions": ["icn1"] }
  },
  "routes": [
    { "src": "/sitemap.xml", "dest": "/api/sitemap.js" },
    { "src": "/p/(.*)", "dest": "/api/post.js?slug=$1" },
    { "src": "/content/detail", "dest": "/api/post.js" },
    { "src": "/guide/(.+)", "dest": "/api/guide.js?slug=$1" },
    { "src": "/guide", "dest": "/api/guide.js" },
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/archive", "dest": "/archive.html" },
    { "src": "/calendar", "dest": "/calendar.html" },
    { "src": "/content", "dest": "/content.html" },
    { "src": "/community/talk", "dest": "/community-talk.html" },
    { "src": "/community/qna", "dest": "/community-qna.html" },
    { "src": "/finder", "dest": "/finder.html" },
    { "src": "/admin", "dest": "/admin.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
